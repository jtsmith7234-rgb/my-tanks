{
  "appId": "com.tankcarebuddy.app",
  "appName": "Tank Care Buddy",
  "webDir": "www",
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "backgroundColor": "#06121a"
